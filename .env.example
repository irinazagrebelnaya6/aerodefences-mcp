# Скопіюй у .env і підстав свої значення (файл .env у git НЕ потрапляє).

# --- Підключення до MySQL ---
ADD_DB_HOST=127.0.0.1
ADD_DB_PORT=3307
ADD_DB_USER=aerodefence
ADD_DB_PASSWORD=CHANGE_ME
ADD_DB_NAME=aerodefences

# Пул зʼєднань і таймаути (сек).
ADD_DB_POOL_SIZE=5
ADD_DB_CONNECT_TIMEOUT=5
ADD_DB_READ_TIMEOUT=10
ADD_DB_WRITE_TIMEOUT=10
# TLS до БД: шлях до CA-сертифіката (порожньо = без TLS, лише для локалі).
ADD_DB_SSL_CA=

# --- docker-compose: секрети MySQL (не в git) ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT

# --- Безпека: роль доступу (viewer | editor | admin) ---
# Прод-дефолт viewer (deny-by-default). Для локального stdio-dev можна підняти
# через ADD_DEV_ROLE (діє лише в stdio-режимі, у HTTP роль береться з JWT).
ADD_ROLE=viewer
# ADD_DEV_ROLE=admin

# --- JWT-автентифікація (ОБОВʼЯЗКОВА для ADD_TRANSPORT=http) ---
# Джерело ключів: або JWKS-URL, або статичний публічний ключ.
ADD_JWT_JWKS_URI=
ADD_JWT_PUBLIC_KEY=
ADD_JWT_ISSUER=
ADD_JWT_AUDIENCE=

# --- Транспорт: stdio (локально) | http (мережевий деплой) ---
ADD_TRANSPORT=stdio
ADD_HTTP_HOST=0.0.0.0
ADD_HTTP_PORT=8000
ADD_METRICS_PORT=9100

# --- Спільний стан сесій (multi-replica); порожньо = памʼять процесу ---
ADD_REDIS_URL=
ADD_SELECTION_TTL=3600

# --- Ліміти вибірки ---
ADD_MAX_LIMIT=200

# --- Логування ---
ADD_LOG_LEVEL=INFO
ADD_LOG_FORMAT=text   # text для локалі, json для проду
